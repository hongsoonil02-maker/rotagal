<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 380 90" width="100%" height="100%">
  <defs>
    <linearGradient id="gold-text" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#D97706" />
      <stop offset="50%" stop-color="#B45309" />
      <stop offset="100%" stop-color="#92400E" />
    </linearGradient>
    <filter id="drop-shadow" x="-10%" y="-10%" width="120%" height="120%">
      <feDropShadow dx="0" dy="1" stdDeviation="1" flood-color="#000000" flood-opacity="0.15"/>
    </filter>
  </defs>

  <!-- Background container -->
  <rect x="2" y="2" width="376" height="86" rx="14" fill="#ffffff" stroke="#E5E7EB" stroke-width="2" filter="url(#drop-shadow)" />

  <!-- Left: EU Flag Rounded Box -->
  <rect x="12" y="10" width="70" height="70" rx="10" fill="#003399" />
  
  <!-- 12 Stars on EU Flag (center at x=47, y=45, r=22) -->
  <g fill="#FFD700">
    <circle cx="47" cy="23" r="2.5" />
    <circle cx="58" cy="26" r="2.5" />
    <circle cx="66" cy="34" r="2.5" />
    <circle cx="69" cy="45" r="2.5" />
    <circle cx="66" cy="56" r="2.5" />
    <circle cx="58" cy="64" r="2.5" />
    <circle cx="47" cy="67" r="2.5" />
    <circle cx="36" cy="64" r="2.5" />
    <circle cx="28" cy="56" r="2.5" />
    <circle cx="25" cy="45" r="2.5" />
    <circle cx="28" cy="34" r="2.5" />
    <circle cx="36" cy="26" r="2.5" />
  </g>

  <!-- Divider line -->
  <line x1="94" y1="16" x2="94" y2="74" stroke="#E5E7EB" stroke-width="2" />

  <!-- Right: Official Text -->
  <text x="108" y="36" font-family="Arial, Helvetica, sans-serif" font-weight="900" font-size="18" fill="#1E3A8A" letter-spacing="1">EUROPEAN UNION</text>
  
  <text x="108" y="62" font-family="Arial, Helvetica, sans-serif" font-weight="900" font-size="24" fill="#047857" letter-spacing="1">GMP</text>
  <text x="172" y="61" font-family="Arial, Helvetica, sans-serif" font-weight="800" font-size="16" fill="#4B5563" letter-spacing="0.5">CERTIFIED</text>

  <!-- Gold decorative underline -->
  <rect x="108" y="70" width="250" height="3" rx="1.5" fill="#D97706" />
</svg>
